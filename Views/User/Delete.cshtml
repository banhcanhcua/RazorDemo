@model RazorDemo.Models.User

@{
    ViewData["Title"] = "Xóa người dùng";
}

<h1>@ViewData["Title"]</h1>

<h3>Bạn có chắc chắn muốn xóa người dùng này?</h3>
<div>
    <h4>Người dùng</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Tên đăng nhập</dt>
        <dd class="col-sm-10">@Model.Username</dd>
        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>
        <dt class="col-sm-2">Vai trò</dt>
        <dd class="col-sm-10">@Model.Role</dd>
    </dl>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Xóa" class="btn btn-danger" /> |
        <a asp-action="Index">Quay lại danh sách</a>
    </form>
</div>