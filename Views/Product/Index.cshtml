@model IEnumerable<RazorDemo.Models.Product>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
    var isAdmin = Context.Session.GetString("Role") == "admin";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@{
    var searchKeyword = ViewData["SearchKeyword"] as string ?? string.Empty;
    var selectedCategoryId = ViewData["CategoryId"] as int?;
}

<div class="page-header">
    <div>
        <span class="eyebrow">Quản lý sản phẩm</span>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0">Tìm kiếm, lọc theo danh mục và thao tác nhanh trên từng sản phẩm.</p>
    </div>
    <div class="page-actions">
        <span class="pill-badge">@Model.Count() sản phẩm đang hiển thị</span>
        @if (isAdmin)
        {
            <a asp-action="Create" class="btn btn-primary">Thêm sản phẩm mới</a>
        }
    </div>
</div>

<div class="filter-panel mb-4">
    <form method="get" class="row gx-3 gy-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label">Từ khóa</label>
            <input name="searchKeyword" value="@searchKeyword" class="form-control" placeholder="Tìm theo tên hoặc mã" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Danh mục</label>
            <select name="categoryId" class="form-select">
                <option value="">Tất cả danh mục</option>
                @if (ViewData["Categories"] is IEnumerable<RazorDemo.Models.Category> categories)
                {
                    foreach (var category in categories)
                    {
                        <option value="@category.Id" selected="@(selectedCategoryId == category.Id ? "selected" : null)">@category.Name</option>
                    }
                }
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Tìm kiếm</button>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary">Xóa tìm kiếm</a>
        </div>
    </form>
    @if (isAdmin)
    {
        <form asp-action="RemoveAll" method="post" class="mt-3">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">Xóa tất cả</button>
        </form>
    }
</div>

<div class="list-panel">
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Tên</th>
                    <th>Giá</th>
                    <th>Danh mục</th>
                    <th>Tồn kho</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="fw-semibold">@item.Name</a>
                        </td>
                        <td><span class="price-tag">@item.Price.ToString("N0") đ</span></td>
                        <td>@item.Category?.Name</td>
                        <td>@item.Stock</td>
                        <td>
                            <div class="inline-actions">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Chi tiết</a>
                                @if (isAdmin)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Xóa</a>
                                }
                                <form asp-controller="Cart" asp-action="Add" method="post" class="m-0">
                                    <input type="hidden" name="productId" value="@item.Id" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <button type="submit" class="btn btn-success btn-sm">Thêm vào giỏ</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@{
    var currentPage = (int)(ViewData["CurrentPage"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
}
<nav aria-label="Page navigation" class="mt-4">
    <ul class="pagination">
        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
            <a class="page-link" href="?page=@(currentPage - 1)&searchKeyword=@searchKeyword&categoryId=@selectedCategoryId">Previous</a>
        </li>
        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == currentPage ? "active" : "")">
                <a class="page-link" href="?page=@i&searchKeyword=@searchKeyword&categoryId=@selectedCategoryId">@i</a>
            </li>
        }
        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
            <a class="page-link" href="?page=@(currentPage + 1)&searchKeyword=@searchKeyword&categoryId=@selectedCategoryId">Next</a>
        </li>
    </ul>
</nav>
