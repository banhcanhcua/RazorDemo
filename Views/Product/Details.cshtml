@model RazorDemo.Models.Product

@{
    ViewData["Title"] = $"Chi tiết sản phẩm: {Model.Name}";
}

<h1>@ViewData["Title"]</h1>

<div>
    <h4>Sản phẩm</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Tên</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Mô tả</dt>
        <dd class="col-sm-10">@Model.Description</dd>
        <dt class="col-sm-2">Giá</dt>
        <dd class="col-sm-10">@Model.Price</dd>
        <dt class="col-sm-2">Danh mục</dt>
        <dd class="col-sm-10">@Model.Category?.Name</dd>
        <dt class="col-sm-2">Tồn kho</dt>
        <dd class="col-sm-10">@Model.Stock</dd>
    </dl>
    @if (Model.ImageUrls.Any())
    {
        <div class="mb-3">
            <h5>Hình ảnh sản phẩm</h5>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var imageUrl in Model.ImageUrls)
                {
                    <img src="@imageUrl" class="img-thumbnail" style="max-height: 180px;" alt="@Model.Name" />
                }
            </div>
        </div>
    }
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sửa</a>
    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
</div>