@* Component: Header + Main Wrapper *@
@model dynamic
<header class="site-header">
    <div class="container">
        <nav class="navbar navbar-expand-lg site-navbar">
            <div class="container-fluid px-0">
                <a class="navbar-brand brand-mark" asp-area="" asp-page="/Index">
                    <span class="brand-badge">RD</span>
                    <span>RazorDemo</span>
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavigation" aria-controls="mainNavigation"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse mt-3 mt-lg-0" id="mainNavigation">
                    <ul class="navbar-nav main-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Trang chủ</a>
                        </li>
                        @if (Model != null && Model.isAuthenticated != null && Convert.ToBoolean(Model.isAuthenticated))
                        {
                            if (Model.role != null && Convert.ToString(Model.role) == "admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Product" asp-action="Index">Sản phẩm</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="User" asp-action="Index">Người dùng</a>
                                </li>
                            }
                        }
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/ContactPage">Liên hệ</a>
                        </li>
                    </ul>
                    <div class="nav-utilities">
                        @if (Model != null && Model.isAuthenticated != null && Convert.ToBoolean(Model.isAuthenticated))
                        {
                            <a class="btn btn-outline-primary btn-sm" asp-controller="Cart" asp-action="Index">Giỏ hàng</a>
                            <span class="user-chip">@(Model.username != null ? Model.username : "") <small>@(Model.role != null ? Model.role : "")</small></span>
                            <form asp-page="/Login" asp-page-handler="Logout" method="post" class="m-0">
                                <button type="submit" class="btn btn-outline-secondary btn-sm">Đăng xuất</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-primary btn-sm" asp-area="" asp-page="/Login">Đăng nhập</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </div>
</header>
