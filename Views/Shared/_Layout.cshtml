@using RazorDemo.Models
@{
    var currentPage = ViewContext?.RouteData.Values["page"]?.ToString();
    var isLoginPage = string.Equals(currentPage, "/Login", StringComparison.OrdinalIgnoreCase);
    var isAuthenticated = Context.Session.GetString("UserId") != null;
    var username = Context.Session.GetString("Username");
    var role = Context.Session.GetString("Role");
    var headerModel = new HeaderMainWrapperViewModel
    {
        IsAuthenticated = isAuthenticated,
        Username = username,
        Role = role
    };
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RazorDemo</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RazorDemo.styles.css" asp-append-version="true" />
</head>
<body class="@(isLoginPage ? "login-page-body" : string.Empty)">
    <div class="app-shell">
        @if (!isLoginPage)
        {
            @await Html.PartialAsync("_HeaderMainWrapper", headerModel)
        }

        <main role="main" class="site-main">
            <div class="container">
                @RenderBody()
            </div>
        </main>

        @if (!isLoginPage)
        {
            <footer class="site-footer">
                <div class="container">
                    <div class="footer-shell">
                        <div>
                            <strong>RazorDemo</strong>
                            <span class="text-muted ms-2">Giao diện mua sắm gọn gàng, hiện đại và dễ dùng.</span>
                        </div>
                        <a asp-area="" asp-page="/Privacy">Privacy</a>
                    </div>
                </div>
            </footer>
        }
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
