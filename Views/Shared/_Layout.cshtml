@{
    var isAuthenticated = Context.Session.GetString("UserId") != null;
    var username = Context.Session.GetString("Username");
    var role = Context.Session.GetString("Role");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RazorDemo</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RazorDemo.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">


        @await Html.PartialAsync("_HeaderMainWrapper", new { isAuthenticated = isAuthenticated, username = username, role = role })

        <main role="main" class="site-main">
            <div class="container">
                @RenderBody()
            </div>
        </main>

        <footer class="site-footer">
            <div class="container">
                <div class="footer-shell">
                    <div>
                        <strong>RazorDemo</strong>
                        <span class="text-muted ms-2">Giao diện mua sắm gọn gàng, hiện đại và dễ dùng.</span>
                    </div>
                    <a asp-area="" asp-page="/Privacy">Privacy</a>
                </div>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
