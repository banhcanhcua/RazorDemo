@model List<RazorDemo.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
    var cartTotal = Model.Sum(item => item.Price * item.Quantity);
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="page-header">
    <div>
        <span class="eyebrow">Giỏ hàng</span>
        <h1>@ViewData["Title"]</h1>
        <p class="mb-0">Kiểm tra lại số lượng, cập nhật đơn giản và xoá sản phẩm nhanh khi cần.</p>
    </div>
    @if (Model.Any())
    {
        <div class="summary-card">
            <span class="muted-text">Tổng tạm tính</span>
            <strong>@cartTotal.ToString("N0") đ</strong>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="list-panel empty-state">
        <h2 class="section-title">Giỏ hàng của bạn đang trống</h2>
        <p class="section-subtitle mb-0">Hãy quay lại danh sách sản phẩm để thêm món hàng bạn muốn mua.</p>
    </div>
}
else
{
    <div class="list-panel">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Giá</th>
                        <th>Số lượng</th>
                        <th>Thành tiền</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.ProductName</td>
                            <td><span class="price-tag">@item.Price.ToString("N0") đ</span></td>
                            <td>
                                <form asp-action="Update" method="post" class="quantity-form m-0">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control" />
                                    <button type="submit" class="btn btn-outline-primary btn-sm">Cập nhật</button>
                                </form>
                            </td>
                            <td class="fw-semibold">@((item.Price * item.Quantity).ToString("N0")) đ</td>
                            <td>
                                <form asp-action="Remove" method="post" class="m-0">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="action-row mt-4">
            <form asp-action="Clear" method="post" class="m-0">
                <button type="submit" class="btn btn-warning">Xóa toàn bộ giỏ hàng</button>
            </form>
            <a asp-area="" asp-page="/Index" class="btn btn-outline-secondary">Tiếp tục mua sắm</a>
        </div>
    </div>
}
