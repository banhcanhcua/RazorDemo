@model List<RazorDemo.Models.Product>

@{
    int currentPage = Convert.ToInt32(ViewData["CurrentPage"] ?? 1);
    string sortOrder = ViewData["SortOrderValue"]?.ToString() ?? "asc";
    string keyword = ViewData["Keyword"]?.ToString() ?? string.Empty;
    int pageSize = Convert.ToInt32(ViewData["PageSize"] ?? 15);
    bool hasNextPage = ViewData["HasNextPage"] is bool nextPage && nextPage;
}

<div class="product-box product-grid-section">
    @if (TempData["SuccessMessage"] != null && !Context.Request.Headers["X-Requested-With"].Equals("XMLHttpRequest"))
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    <div class="product-box-header">
        <div>
            <span class="eyebrow">Top sản phẩm nổi bật</span>
            <h2 class="section-title">Sản phẩm hot và mới cập nhật</h2>
            <p class="section-subtitle mb-0">Danh sách gợi ý để bạn xem nhanh những mặt hàng nổi bật, mới lên kệ và đáng chú ý.</p>
        </div>
        <span class="pill-badge">Trang @ViewData["CurrentPage"]</span>
    </div>
    @if (Model.Count == 0)
    {
        <div class="empty-state py-4 text-center">
            <p class="mb-0">Không tìm thấy sản phẩm phù hợp.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3">
            @foreach (var product in Model)
            {
                <div class="col mb-4">
                    @await Html.PartialAsync("_ProductItem", product)
                </div>
            }
        </div>
    }
    <div class="mt-3">
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="?page=@(currentPage - 1)&SortOrder=@sortOrder&pageSize=@pageSize&keyword=@Uri.EscapeDataString(keyword)#product-list">Previous</a>
                </li>
                <li class="page-item">
                    <span class="page-link">Trang @currentPage</span>
                </li>
                <li class="page-item @(hasNextPage ? string.Empty : "disabled")">
                    <a class="page-link" href="?page=@(currentPage + 1)&SortOrder=@sortOrder&pageSize=@pageSize&keyword=@Uri.EscapeDataString(keyword)#product-list">Next</a>
                </li>
            </ul>
        </nav>
    </div>
</div>
