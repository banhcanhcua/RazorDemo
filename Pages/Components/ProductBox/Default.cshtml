@model List<RazorDemo.Models.Product>

<div class="product-box product-grid-section">
    @if (TempData["SuccessMessage"] != null && !Context.Request.Headers["X-Requested-With"].Equals("XMLHttpRequest"))
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    <div class="product-box-header">
        <div>
            <span class="eyebrow">Top sản phẩm nổi bật</span>
            <h2 class="section-title">Sản phẩm hot và mới cập nhật</h2>
            <p class="section-subtitle mb-0">Danh sách gợi ý để bạn xem nhanh những mặt hàng nổi bật, mới lên kệ và đáng chú ý.</p>
        </div>
        <span class="pill-badge">Trang @ViewData["CurrentPage"]</span>
    </div>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3">
        @foreach (var product in Model)
        {
            <div class="col mb-4">
                @await Html.PartialAsync("_ProductItem", product)
            </div>
        }
    </div>
    <div class="mt-3">
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Convert.ToInt32(ViewData["CurrentPage"]) == 1 ? "disabled" : "")">
                    <a class="page-link" href="?page=@(Convert.ToInt32(ViewData["CurrentPage"]) - 1)">Previous</a>
                </li>
                <li class="page-item">
                    <span class="page-link">Trang @(ViewData["CurrentPage"])</span>
                </li>
                <li class="page-item">
                    <a class="page-link" href="?page=@(Convert.ToInt32(ViewData["CurrentPage"]) + 1)">Next</a>
                </li>
            </ul>
        </nav>
    </div>
</div>
