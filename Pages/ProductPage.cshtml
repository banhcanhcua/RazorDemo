@page "/product/{id:int?}"
@model RazorDemo.Pages.ProductPageModel
@using RazorDemo.Models

@{
    ViewData["Title"] = Model.PageTitle;
}

<h1>@ViewData["Title"]</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (Model.Product == null)
{
    <div class="mb-4">
        <form method="get" class="row gx-2 gy-2 align-items-center">
            <div class="col-auto">
                <input asp-for="SearchKeyword" class="form-control" placeholder="Tìm theo tên hoặc mã" />
            </div>
            <div class="col-auto">
                <select asp-for="CategoryId" class="form-select">
                    <option value="">Tất cả danh mục</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <select name="SortOrder" class="form-select">
                    @if (Request.Query["SortOrder"] == "desc")
                    {
                        <option value="asc">Giá thấp đến cao</option>
                        <option value="desc" selected>Giá cao đến thấp</option>
                    }
                    else
                    {
                        <option value="asc" selected>Giá thấp đến cao</option>
                        <option value="desc">Giá cao đến thấp</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Tìm kiếm</button>
            </div>
            <div class="col-auto">
                <a asp-page="ProductPage" class="btn btn-secondary">Xóa tìm kiếm</a>
            </div>
            <div class="col-auto">
                <a asp-page="ProductPage" asp-page-handler="RemoveAll" class="btn btn-danger">Xóa tất cả</a>
            </div>
        </form>
    </div>
}

@if (Model.Product != null)
{
    <div class="card mb-4">
        <div class="card-body">
            <h2>@Model.Product.Name</h2>
            <p>Mô tả: @Model.Product.Description</p>
            <p>Giá: @Model.Product.Price</p>
            <p>Số lượng tồn kho: @Model.Product.Stock</p>
            <p>Danh mục: @Model.Product.Category?.Name</p>
            @if (Model.Product.ImageUrls.Any())
            {
                <div class="mb-3">
                    <div class="d-flex align-items-center mb-2 gap-2">
                        <h5 class="mb-0">Hình ảnh sản phẩm</h5>
                        <button type="button" class="btn btn-sm btn-danger" id="deleteAllImagesBtn">Xóa tất cả ảnh</button>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var imageUrl in Model.Product.ImageUrls)
                        {
                            <img src="@imageUrl" class="img-thumbnail" style="max-height: 180px;" alt="@Model.Product.Name" />
                        }
                    </div>
                </div>
            }
            <a href="/product" class="btn btn-link">Danh sách sản phẩm</a>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h3>Cập nhật sản phẩm</h3>
            <form method="post" enctype="multipart/form-data" asp-page-handler="Update">
                <div asp-validation-summary="All" class="text-danger"></div>
                <input type="hidden" asp-for="ProductUpdate.Id" />
                <div class="mb-3">
                    <label class="form-label">Tên</label>
                    <input asp-for="ProductUpdate.Name" class="form-control" />
                    <span asp-validation-for="ProductUpdate.Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <input asp-for="ProductUpdate.Description" class="form-control" />
                    <span asp-validation-for="ProductUpdate.Description" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Giá</label>
                    <input asp-for="ProductUpdate.Price" class="form-control" />
                    <span asp-validation-for="ProductUpdate.Price" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Số lượng tồn kho</label>
                    <input asp-for="ProductUpdate.Stock" class="form-control" />
                    <span asp-validation-for="ProductUpdate.Stock" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Danh mục</label>
                    <select asp-for="ProductUpdate.CategoryId" class="form-select">
                        <option value="">Chọn danh mục</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
                    <span asp-validation-for="ProductUpdate.CategoryId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Cập nhật hình ảnh mới</label>
                    <input type="file" name="UploadedImages" class="form-control" multiple accept="image/*" />
                </div>
                <button type="submit" class="btn btn-warning">Lưu thay đổi</button>
            </form>
        </div>
    </div>
}
else
{
    <div class="mb-4">
        <h3>Danh sách sản phẩm</h3>
        @if (!string.IsNullOrWhiteSpace(Model.SearchKeyword))
        {
            <p>Kết quả tìm kiếm cho "<strong>@Model.SearchKeyword</strong>"</p>
        }
        <ul class="list-group">
            @foreach (var item in Model.Products)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <a asp-page="ProductPage" asp-route-id="@item.Id">@item.Name</a>
                        <br><small class="text-muted">@item.Category?.Name - Giá: @item.Price - Tồn kho: @item.Stock</small>
                    </div>
                    <form method="post" asp-page-handler="Delete" class="m-0">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                    </form>
                </li>
            }
        </ul>
        <nav aria-label="Page navigation">
            <ul class="pagination mt-3">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="?page=@(Model.CurrentPage - 1)">Previous</a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="?page=@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="?page=@(Model.CurrentPage + 1)">Next</a>
                </li>
            </ul>
        </nav>
    </div>
}

@if (Model.Product == null)
{
    <div class="card">
        <div class="card-body">
            <h3>Thêm sản phẩm mới</h3>
            <form method="post" asp-page-handler="Create" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="text-danger"></div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Tên</label>
                        <input asp-for="NewProduct.Name" class="form-control" />
                        <span asp-validation-for="NewProduct.Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Giá</label>
                        <input asp-for="NewProduct.Price" class="form-control" />
                        <span asp-validation-for="NewProduct.Price" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Số lượng tồn kho</label>
                        <input asp-for="NewProduct.Stock" class="form-control" />
                        <span asp-validation-for="NewProduct.Stock" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Mô tả</label>
                        <input asp-for="NewProduct.Description" class="form-control" />
                        <span asp-validation-for="NewProduct.Description" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Danh mục</label>
                        <select asp-for="NewProduct.CategoryId" class="form-select">
                            <option value="">Chọn danh mục</option>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </select>
                        <span asp-validation-for="NewProduct.CategoryId" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Hình ảnh</label>
                        <input asp-for="UploadedImages" type="file" class="form-control" multiple />
                        <span asp-validation-for="UploadedImages" class="text-danger"></span>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary mt-3">Thêm sản phẩm</button>
            </form>
        </div>
    </div>
}
