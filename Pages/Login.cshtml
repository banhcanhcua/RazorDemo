@page
@model RazorDemo.Pages.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-shell">
    <a class="auth-brand" asp-area="" asp-page="/Index">
        <span class="brand-badge auth-brand-badge">RD</span>
        <span class="auth-brand-name">RazorDemo</span>
    </a>

    <div class="auth-card">
        <span class="eyebrow">Chào mừng trở lại</span>
        <h1>Đăng nhập</h1>
        <p class="mb-4 auth-description">Đăng nhập để quản lý sản phẩm, người dùng và tiếp tục mua sắm thuận tiện hơn.</p>

        <form method="post">
            <div asp-validation-summary="All" class="text-danger auth-validation"></div>
            <div class="auth-field">
                <label class="form-label auth-label">Email</label>
                <input asp-for="LoginEmail" class="form-control auth-input" />
            </div>
            <div class="auth-field">
                <label class="form-label auth-label">Password</label>
                <input asp-for="LoginPassword" class="form-control auth-input" type="password" />
            </div>
            <div class="auth-actions">
                <button type="submit" class="btn btn-primary auth-submit-button">Đăng nhập</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
