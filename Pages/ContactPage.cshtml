@page "/ContactPage"
@model RazorDemo.Pages.ContactPageModel

@{
    ViewData["Title"] = "LIÊN HỆ";
}

<div class="page-header">
    <div>
        <span class="eyebrow">Kết nối với chúng tôi</span>
        <h1>Trang liên hệ</h1>
        <p class="mb-0">Điền thông tin để gửi yêu cầu và theo dõi lại dữ liệu vừa nhập một cách trực quan.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="form-panel h-100">
            <form method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" asp-for="contact.FirstName"></label>
                        <input class="form-control" asp-for="contact.FirstName" />
                        <span class="text-danger" asp-validation-for="contact.FirstName"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="contact.LastName"></label>
                        <input class="form-control" asp-for="contact.LastName" />
                        <span class="text-danger" asp-validation-for="contact.LastName"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="contact.DateOfBirth"></label>
                        @if (Model.contact.DateOfBirth == DateTime.MinValue)
                        {
                            <input class="form-control" name="contact.DateOfBirth" type="date" value="" />
                        }
                        else
                        {
                            <input class="form-control" name="contact.DateOfBirth" type="date" value="@Model.contact.DateOfBirth.ToString("yyyy-MM-dd")" />
                        }
                        <span class="text-danger" asp-validation-for="contact.DateOfBirth"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="contact.Email"></label>
                        <input class="form-control" asp-for="contact.Email" />
                        <span class="text-danger" asp-validation-for="contact.Email"></span>
                    </div>
                </div>

                <div class="action-row mt-4">
                    <button class="btn btn-primary" type="submit">Gửi liên hệ</button>
                </div>
            </form>
        </div>
    </div>
    <div class="col-lg-5">
        @if (!string.IsNullOrEmpty(Model.thongbao))
        {
            <div class="alert alert-danger">@Model.thongbao</div>
        }

        <div class="detail-panel h-100">
            <span class="eyebrow">Xem trước dữ liệu</span>
            <h2 class="section-title">Thông tin Contact</h2>
            <dl class="detail-list mt-4">
                <div>
                    <dt>ContactId</dt>
                    <dd>@Model.contact.ContactId</dd>
                </div>
                <div>
                    <dt>FirstName</dt>
                    <dd>@Model.contact.FirstName</dd>
                </div>
                <div>
                    <dt>LastName</dt>
                    <dd>@Model.contact.LastName</dd>
                </div>
                <div>
                    <dt>DateOfBirth</dt>
                    <dd>@(Model.contact.DateOfBirth == DateTime.MinValue ? "" : Model.contact.DateOfBirth.ToString("dd/MM/yyyy"))</dd>
                </div>
                <div>
                    <dt>Email</dt>
                    <dd>@Model.contact.Email</dd>
                </div>
            </dl>
        </div>
    </div>
</div>
