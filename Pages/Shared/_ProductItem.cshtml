@using RazorDemo.Models
@model Product

@{
    var imageUrl = Model.ImageUrls != null && Model.ImageUrls.Any() ? Model.ImageUrls[0] : null;
    var previewLetter = !string.IsNullOrWhiteSpace(Model.Name) ? Model.Name.Substring(0, 1).ToUpperInvariant() : "P";
    var description = string.IsNullOrWhiteSpace(Model.Description) ? "Sản phẩm đang được cập nhật thêm mô tả chi tiết." : Model.Description;
}

<div class="card product-card">
    @if (!string.IsNullOrWhiteSpace(imageUrl))
    {
        <img src="@imageUrl" alt="@Model.Name" class="product-card-media" />
    }
    else
    {
        <div class="product-card-preview">@previewLetter</div>
    }
    <div class="product-card-body">
        <div class="product-meta">
            <div class="product-copy">
                <h3 class="product-title">@Model.Name</h3>
                <p class="product-description">@description</p>
                <span class="price-tag">@Model.Price.ToString("N0") đ</span>
            </div>
        </div>
        <form asp-controller="Cart" asp-action="Add" method="post">
            <input type="hidden" name="productId" value="@Model.Id" />
            <input type="hidden" name="quantity" value="1" />
            <button type="submit" class="btn btn-success w-100">Thêm vào giỏ</button>
        </form>
    </div>
</div>
