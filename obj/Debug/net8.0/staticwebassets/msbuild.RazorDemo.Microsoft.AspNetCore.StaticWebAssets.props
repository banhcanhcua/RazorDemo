      <OriginalItemSpec>$([System.IO.Path]::GetFullPath($(MSBuildThisFileDirectory)..\staticwebassets\RazorDemo.bundle.scp.css))</OriginalItemSpec>
    </StaticWebAsset>
  </ItemGroup>
</Project>